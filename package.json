{
  "name": "ethereum-cryptography",
  "version": "3.2.0",
  "description": "All the cryptographic primitives used in Ethereum.",
  "repository": "https://github.com/ethereum/js-ethereum-cryptography",
  "license": "MIT",
  "type": "module",
  "main": "./index.js",
  "module": "./index.js",
  "engines": {
    "node": ">= 20.19.0"
  },
  "files": [
    "bip39/*.js",
    "bip39/*.d.ts",
    "bip39/wordlists/*.js",
    "bip39/wordlists/*.d.ts",
    "*.js",
    "*.d.ts"
  ],
  "dependencies": {
    "@noble/ciphers": "2.2.0",
    "@noble/curves": "2.2.0",
    "@noble/hashes": "2.2.0",
    "@scure/bip32": "2.2.0",
    "@scure/bip39": "2.2.0"
  },
  "exports": {
    ".": "./index.js",
    "./aes": "./aes.js",
    "./bip39": "./bip39/index.js",
    "./blake2b": "./blake2b.js",
    "./bls": "./bls.js",
    "./bn": "./bn.js",
    "./hdkey": "./hdkey.js",
    "./index": "./index.js",
    "./math": "./math.js",
    "./keccak": "./keccak.js",
    "./pbkdf2": "./pbkdf2.js",
    "./random": "./random.js",
    "./ripemd160": "./ripemd160.js",
    "./scrypt": "./scrypt.js",
    "./secp256k1-compat": "./secp256k1-compat.js",
    "./secp256k1": "./secp256k1.js",
    "./sha256": "./sha256.js",
    "./sha512": "./sha512.js",
    "./utils": "./utils.js",
    "./bip39/index": "./bip39/index.js",
    "./bip39/wordlists/czech": "./bip39/wordlists/czech.js",
    "./bip39/wordlists/english": "./bip39/wordlists/english.js",
    "./bip39/wordlists/french": "./bip39/wordlists/french.js",
    "./bip39/wordlists/italian": "./bip39/wordlists/italian.js",
    "./bip39/wordlists/japanese": "./bip39/wordlists/japanese.js",
    "./bip39/wordlists/korean": "./bip39/wordlists/korean.js",
    "./bip39/wordlists/simplified-chinese": "./bip39/wordlists/simplified-chinese.js",
    "./bip39/wordlists/spanish": "./bip39/wordlists/spanish.js",
    "./bip39/wordlists/traditional-chinese": "./bip39/wordlists/traditional-chinese.js",
    "./aes.js": "./aes.js",
    "./bip39.js": "./bip39/index.js",
    "./blake2b.js": "./blake2b.js",
    "./bls.js": "./bls.js",
    "./bn.js": "./bn.js",
    "./hdkey.js": "./hdkey.js",
    "./index.js": "./index.js",
    "./math.js": "./math.js",
    "./keccak.js": "./keccak.js",
    "./pbkdf2.js": "./pbkdf2.js",
    "./random.js": "./random.js",
    "./ripemd160.js": "./ripemd160.js",
    "./scrypt.js": "./scrypt.js",
    "./secp256k1-compat.js": "./secp256k1-compat.js",
    "./secp256k1.js": "./secp256k1.js",
    "./sha256.js": "./sha256.js",
    "./sha512.js": "./sha512.js",
    "./utils.js": "./utils.js",
    "./bip39/index.js": "./bip39/index.js",
    "./bip39/wordlists/czech.js": "./bip39/wordlists/czech.js",
    "./bip39/wordlists/english.js": "./bip39/wordlists/english.js",
    "./bip39/wordlists/french.js": "./bip39/wordlists/french.js",
    "./bip39/wordlists/italian.js": "./bip39/wordlists/italian.js",
    "./bip39/wordlists/japanese.js": "./bip39/wordlists/japanese.js",
    "./bip39/wordlists/korean.js": "./bip39/wordlists/korean.js",
    "./bip39/wordlists/simplified-chinese.js": "./bip39/wordlists/simplified-chinese.js",
    "./bip39/wordlists/spanish.js": "./bip39/wordlists/spanish.js",
    "./bip39/wordlists/traditional-chinese.js": "./bip39/wordlists/traditional-chinese.js"
  },
  "browser": {
    "crypto": false
  },
  "sideEffects": false,
  "scripts": {
    "prepare": "npm run build",
    "build": "npm-run-all build:tsc",
    "build:tsc": "tsc --project tsconfig.prod.json",
    "test": "npm-run-all test:node",
    "test:node": "cd test && npm install && cd .. && mocha",
    "clean": "rm -rf test/test-builds bip39 *.js *.js.map *.d.ts *.d.ts.map src/**/*.js",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "browser-tests": "npm-run-all browser-tests:build browser-tests:test",
    "browser-tests:build": "bash -x ./scripts/build-browser-tests.sh",
    "browser-tests:test": "npm-run-all browser-tests:test-parcel browser-tests:test-webpack browser-tests:test-rollup",
    "browser-tests:test-parcel": "karma start --single-run --browsers ChromeHeadless test/karma.parcel.conf.js",
    "browser-tests:test-webpack": "karma start --single-run --browsers ChromeHeadless test/karma.webpack.conf.js",
    "browser-tests:test-rollup": "karma start --single-run --browsers ChromeHeadless test/karma.rollup.conf.js"
  },
  "devDependencies": {
    "@types/estree": "1.0.0",
    "@types/mocha": "10.0.7",
    "@types/node": "22.14.1",
    "@typescript-eslint/eslint-plugin": "5.30.6",
    "@typescript-eslint/parser": "5.30.6",
    "eslint": "8.38.0",
    "eslint-plugin-prettier": "4.2.1",
    "karma": "6.4.4",
    "karma-chrome-launcher": "3.1.1",
    "karma-mocha": "2.0.1",
    "karma-mocha-reporter": "2.2.5",
    "mocha": "12.0.0-beta-9.2",
    "npm-run-all": "4.1.5",
    "prettier": "2.7.1",
    "ts-node": "10.9.2",
    "typescript": "5.8.3"
  },
  "packageManager": "npm@9.9.4",
  "keywords": [
    "ethereum",
    "cryptography",
    "digital signature",
    "hash",
    "encryption",
    "prng",
    "keccak",
    "scrypt",
    "pbkdf2",
    "sha-256",
    "ripemd-160",
    "blake2b",
    "aes",
    "advanced encryption standard",
    "secp256k1",
    "ecdsa",
    "bip32",
    "hierarchical deterministic keys",
    "hdwallet",
    "hdkeys"
  ],
  "contributors": [
    {
      "name": "Patricio Palladino",
      "email": "patricio@nomiclabs.io"
    },
    {
      "name": "Paul Miller",
      "url": "https://paulmillr.com"
    }
  ],
  "targets": {
    "parcel_tests": {
      "context": "browser"
    }
  }
}
